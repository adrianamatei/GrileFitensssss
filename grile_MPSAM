  { category:"Echipa de Dezvoltare Software", question:"Echipa de intervenție rapidă ('tiger team') are dimensiunea medie de:", options:["5-7 persoane","1-2 persoane, cu durată de viață de 1-2 săptămâni","10-15 persoane","3-5 persoane, permanent"], answer:1, explanation:"Echipa de intervenție: 1-2 persoane, durată de 1-2 săptămâni. Scop: investigarea aspectelor neclare, validarea alternativelor de proiectare, depistarea și înlăturarea bug-urilor." },

  { category:"Abordarea Sistemică", question:"Un sistem (în contextul ingineriei software) este definit ca:", options:["Un set de programe care rulează simultan","O colecție de obiecte și activități plus relațiile dintre ele, cu intrări, acțiuni și ieșiri","Un hardware specific și software-ul asociat","O bază de date cu informațiile proiectului"], answer:1, explanation:"Un sistem = o colecție de obiecte și activități plus o descriere a relațiilor care leagă obiectivele și activitățile împreună (intrări, acțiuni, ieșiri)." },
  { category:"Abordarea Sistemică", question:"Elementele unui sistem sunt:", options:["Hardware, software și documentație","Activități (events inițiate de un trigger), obiecte/entități și relații (inclusiv marginile sistemului)","Intrări, procesare și ieșiri","Utilizatori, date și funcții"], answer:1, explanation:"Elementele unui sistem: Activități (ceva ce se întâmplă, inițiate de un trigger – transformă ceva), Obiecte/Entități (elementele implicate în activități) și Relații (inclusiv marginile sistemului)." }
];

// ── State ──────────────────────────────────────────────────────────────────
const allCategories = ["Toate", ...Array.from(new Set(questions.map(q => q.category)))];

const badgeClass = (() => {
  const map = {};
  allCategories.slice(1).forEach((c, i) => { map[c] = "badge-" + i; });
  return c => map[c] || "badge-0";
})();

let state = {
  mode: "quiz",           // quiz | results | review
  category: "Toate",
  filtered: [...questions],
  current: 0,
  selected: null,
  score: 0,
  answered: [],           // [{qi, sel, correct}]
};

function filteredList(cat) {
  return cat === "Toate" ? questions : questions.filter(q => q.category === cat);
}

function resetQuiz(cat) {
  state.category = cat;
  state.filtered = filteredList(cat);
  state.current = 0;
  state.selected = null;
  state.score = 0;
  state.answered = [];
  state.mode = "quiz";
  render();
}

function selectAnswer(idx) {
  if (state.selected !== null) return;
  const q = state.filtered[state.current];
  const correct = idx === q.answer;
  state.selected = idx;
  if (correct) state.score++;
  state.answered.push({ qi: state.current, sel: idx, correct });
  render();
}

function nextQuestion() {
  if (state.current < state.filtered.length - 1) {
    state.current++;
    state.selected = null;
    render();
  } else {
    state.mode = "results";
    render();
  }
}

// ── Render ─────────────────────────────────────────────────────────────────
function render() {
  const app = document.getElementById("app");
  if (state.mode === "results") { app.innerHTML = renderResults(); return; }
  if (state.mode === "review")  { app.innerHTML = renderReview();  return; }
  app.innerHTML = renderQuiz();
}

function renderQuiz() {
  const { filtered, current, selected, score, category } = state;
  const q = filtered[current];
  const pct = Math.round(((current + 1) / filtered.length) * 100);

  const catButtons = allCategories.map(c => {
    const label = c === "Toate" ? `Toate (${questions.length})` : (c.length > 26 ? c.slice(0, 26) + "…" : c);
    return `<button class="cat-btn${c === category ? " active" : ""}" onclick="resetQuiz('${esc(c)}')">${label}</button>`;
  }).join("");

  const optButtons = q.options.map((opt, idx) => {
    let cls = "";
    if (selected !== null) {
      if (idx === q.answer) cls = " correct";
      else if (idx === selected) cls = " wrong";
      else cls = " dimmed";
    }
    const letter = String.fromCharCode(65 + idx);
    return `<button class="option-btn${cls}" onclick="selectAnswer(${idx})" ${selected !== null ? "disabled" : ""}>
      <span class="letter">${letter}.</span>${esc(opt)}
    </button>`;
  }).join("");

  const expl = selected !== null ? `
    <div class="explanation ${selected === q.answer ? 'ok' : 'bad'}">
      <strong>${selected === q.answer ? "✅ Corect!" : "❌ Greșit!"}</strong>
      ${esc(q.explanation)}
    </div>` : "";

  const nextBtn = selected !== null ? `
    <button class="next-btn" onclick="nextQuestion()">
      ${current < filtered.length - 1 ? "Următoarea întrebare →" : "Vezi rezultatele 🏁"}
    </button>` : "";

  return `
    <div class="container">
      <div class="card header">
        <h1>📋 Grile MPSAM</h1>
        <p>Managementul Proiectelor Software în Aplicații Medicale</p>
        <div class="cats">${catButtons}</div>
      </div>

      <div class="card">
        <div class="progress-row">
          <span>Întrebarea ${current + 1} din ${filtered.length}</span>
          <span class="score">✓ ${score} corecte</span>
        </div>
        <div class="progress-bar-bg">
          <div class="progress-bar-fill" style="width:${pct}%"></div>
        </div>
      </div>

      <div class="card">
        <span class="cat-badge ${badgeClass(q.category)}">${esc(q.category)}</span>
        <div class="question-text">${esc(q.question)}</div>
        <div class="options">${optButtons}</div>
        ${expl}
      </div>

      ${nextBtn}
    </div>`;
}

function renderResults() {
  const { filtered, score, category } = state;
  const pct = Math.round((score / filtered.length) * 100);
  const emoji = pct >= 80 ? "🎉" : pct >= 60 ? "👍" : "📚";
  const color = pct >= 80 ? "#16a34a" : pct >= 60 ? "#d97706" : "#dc2626";

  return `
    <div class="results-center">
      <div class="results-card">
        <div class="results-emoji">${emoji}</div>
        <h2>Rezultate finale</h2>
        <p class="sub">Categorie: ${esc(category)}</p>
        <div class="score-big" style="color:${color}">${score} / ${filtered.length}</div>
        <div class="score-pct">${pct}% corect</div>
        <div class="results-bar-bg">
          <div class="results-bar-fill" style="width:${pct}%; background:${color}"></div>
        </div>
        <div class="btn-group">
          <button class="btn-primary btn-dark" onclick="resetQuiz('${esc(state.category)}')">🔄 Reia testul</button>
          <button class="btn-primary btn-indigo" onclick="goReview()">📖 Revizuiește răspunsurile</button>
        </div>
      </div>
    </div>`;
}

function renderReview() {
  const { filtered, score, answered } = state;
  const pct = Math.round((score / filtered.length) * 100);

  const items = filtered.map((q, qi) => {
    const ans = answered.find(a => a.qi === qi);
    if (!ans) return "";
    const opts = q.options.map((opt, oi) => {
      let cls = "";
      if (oi === q.answer) cls = " r-correct";
      else if (oi === ans.sel && !ans.correct) cls = " r-wrong";
      const mark = oi === q.answer ? "✓ " : (oi === ans.sel && !ans.correct ? "✗ " : "");
      return `<div class="review-opt${cls}">${mark}${esc(opt)}</div>`;
    }).join("");

    return `
      <div class="review-item ${ans.correct ? 'correct-item' : 'wrong-item'}">
        <span class="cat-badge ${badgeClass(q.category)}" style="font-size:.65rem">${esc(q.category)}</span>
        <div class="q-text">${esc(q.question)}</div>
        ${opts}
        <div class="review-expl">💡 ${esc(q.explanation)}</div>
      </div>`;
  }).join("");

  return `
    <div class="container">
      <div class="card review-header">
        <h2>📖 Revizuire răspunsuri</h2>
        <p>Score: ${score}/${filtered.length} (${pct}%)</p>
        <button class="btn-back" onclick="resetQuiz('${esc(state.category)}')">← Reia testul</button>
      </div>
      ${items}
    </div>`;
}

function goReview() { state.mode = "review"; render(); }

function esc(s) {
  return String(s)
    .replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;")
    .replace(/"/g,"&quot;").replace(/'/g,"&#39;");
}

// Boot
render();
</script>
